rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can read their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && isFounder();
    }
    
    // Personal tasks - only owner
    match /personal_tasks/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Shared tasks - team access based on role
    match /tasks/{taskId} {
      allow read: if request.auth != null && isTeamMember();
      allow write: if request.auth != null && hasRole(['founder', 'director', 'manager']);
      allow update: if request.auth != null && (
        isAssignedTo(taskId) || hasRole(['founder', 'director'])
      );
    }
    
    // Objects - role based
    match /objects/{objectId} {
      allow read: if request.auth != null && canAccessObject(objectId);
      allow write: if request.auth != null && hasRole(['founder', 'director']);
      
      // Object subcollections
      match /tasks/{taskId} { allow read, write: if request.auth != null && canAccessObject(objectId); }
      match /decisions/{decisionId} { allow read, write: if request.auth != null && canAccessObject(objectId); }
      match /supplies/{supplyId} { allow read, write: if request.auth != null && canAccessObject(objectId); }
      match /messages/{messageId} { allow read, write: if request.auth != null && canAccessObject(objectId); }
      match /photos/{photoId} { allow read, write: if request.auth != null && canAccessObject(objectId); }
      match /checklists/{checklistId} { allow read, write: if request.auth != null && canAccessObject(objectId); }
    }
    
    // Team/Masters
    match /team/{memberId} {
      allow read: if request.auth != null && (
        hasRole(['founder', 'director', 'manager']) || 
        request.auth.uid == memberId
      );
      allow write: if request.auth != null && hasRole(['founder', 'director']);
    }
    
    // Counterparties
    match /counterparties/{id} {
      allow read: if request.auth != null && hasRole(['founder', 'director', 'manager']);
      allow write: if request.auth != null && hasRole(['founder', 'director']);
    }
    
    // Goals - personal only
    match /goals/{userId}/{goalId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Notifications
    match /notifications/{userId}/{notifId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Helper functions
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasRole(roles) {
      return getUserData().role in roles;
    }
    function isFounder() {
      return getUserData().role == 'founder';
    }
    function isTeamMember() {
      return getUserData() != null;
    }
    function canAccessObject(objectId) {
      let obj = get(/databases/$(database)/documents/objects/$(objectId)).data;
      let role = getUserData().role;
      return role in ['founder', 'director'] || 
             (role == 'manager' && request.auth.uid in obj.managerIds) ||
             (role == 'master' && request.auth.uid in obj.masterIds);
    }
    function isAssignedTo(taskId) {
      return get(/databases/$(database)/documents/tasks/$(taskId)).data.assignedTo == request.auth.uid;
    }
  }
}
